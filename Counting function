#include <iostream>
#include <Windows.h>

void Function()
{
    static int counter = 0;
    counter++;

    std::cout << "Количество вызовов функции counting_function(): " << counter << std::endl;
}

int main(int argc, char** argv)
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    for (int i = 0; i < 15; i++)
    {
        Function();
    }

    return EXIT_SUCCESS;
}

